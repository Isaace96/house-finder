{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run review app",
      "type": "process",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["review.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:\\Program Files\\Tesseract-OCR;${env:PATH}"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*\\*\\s*Serving Flask app",
          "endsPattern": "Running on http://"
        }
      }
    },
    {
      "label": "Run scraper",
      "type": "process",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["main.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:\\Program Files\\Tesseract-OCR;${env:PATH}"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
